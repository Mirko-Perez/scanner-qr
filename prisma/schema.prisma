generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Table {
  id        Int      @id @default(autoincrement())
  number    Int      @unique
  name      String?
  videoPath String?
  guests    Guest[]
  createdAt DateTime @default(now())
}

model Guest {
  id         String    @id @default(uuid())
  name       String
  lastName   String
  tableId    Int
  table      Table     @relation(fields: [tableId], references: [id], onDelete: Cascade)
  hasArrived Boolean   @default(false)
  arrivedAt  DateTime?
  createdAt  DateTime  @default(now())
  scanLogs   ScanLog[]
}

/// Stores every scan event (new arrival or repeat) so the display can poll for updates.
model ScanLog {
  id        Int      @id @default(autoincrement())
  guestId   String
  guest     Guest    @relation(fields: [guestId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
